# Database
# In Docker Compose the backend reaches Postgres via the "db" service hostname.
# To run the backend on your host against the Compose database, swap "db" for "localhost".
DATABASE_URL=postgresql+psycopg://dogs:dogs@db:5432/dogs_db

# Azure OpenAI (required for the AI chat endpoint)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# Chat model deployment used by the summarizer agent that turns breed data
# into an owner-perspective paragraph before embedding.
AZURE_OPENAI_SUMMARIZER_MODEL=gpt-5.4-mini

# Embedding deployment used to embed the owner-perspective summary.
# Dimension must match the deployed model and is fixed at table-create time.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
